# Auth secrets
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=dev@kenzap.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password

# Development DB
POSTGRES_DB=cloud
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_pgadmin_password
DATABASE_URL=postgresql://postgres:your_pgadmin_password@postgres:5432/cloud

# Redis Configuration
REDIS_URL=redis://redis:6379

# Optional local port overrides (docker-compose host bindings)
# POSTGRES_PORT=5432
# ADMINER_PORT=8888
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# APP_PORT=3000
# LIVERELOAD_PORT=35729
# REDIS_PORT=6379

# S3 Bucket Configuration: s3|oss
STORAGE_PROVIDER=s3

# S3/MinIO
S3_ENDPOINT=http://minio:9000
S3_REGION=any
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=kenzap
S3_BUCKET_PRIVATE=kenzap-private

# OSS (optional)
OSS_REGION=...
OSS_ACCESS_KEY_ID=...
OSS_ACCESS_KEY_SECRET=...
OSS_BUCKET=...
OSS_ENDPOINT=...

# SMTP Email Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Defaults
SID=1000000
LOCALE=en

# Application URLs
CDN=http://localhost:3000/files/

# Admin Email
ADMIN_EMAIL=dev@kenzap.com

# Kenzap API Key
KENZAP_API_KEY=your_kenzap_api_key
